{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"baseUrl": ".",
		"noEmit": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"types": ["node", "@playwright/test"],
		"paths": {
			"@pages/*": ["src/e2e/page-objects/*"],
			"@fixtures/*": ["src/e2e/fixtures/*"]
		}
	},
	"include": ["playwright.config.ts", "src/e2e/**/*.ts"],
	"exclude": ["node_modules"]
}